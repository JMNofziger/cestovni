# Copy this file to:  .secrets/linear.env
# The .secrets/ directory is gitignored — keep your real key only there.
#
#   mkdir -p .secrets && cp .secrets.example/linear.env .secrets/linear.env
#   chmod 600 .secrets/linear.env
#   $EDITOR .secrets/linear.env
#
# Used by: scripts/linear-workspace-bootstrap.mjs, scripts/linear-ces57-closeout.mjs
# Cloud Agents: also add LINEAR_API_KEY in Cursor Dashboard → Cloud → Environment secrets
#   (see docs/linear/mcp-setup.md — MCP OAuth may be needsAuth in cloud until fixed)

LINEAR_API_KEY=

# Optional overrides (defaults shown in script):
# LINEAR_TEAM_NAME=Cestovni
# LINEAR_PROJECT_NAME=Cestovni
