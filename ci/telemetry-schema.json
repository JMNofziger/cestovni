{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JMNofziger/cestovni/blob/main/ci/telemetry-schema.json",
  "title": "Cestovni telemetry allow-list schema",
  "description": "Validates docs/specs/telemetry-events.v1.yaml. Rules source: docs/specs/telemetry-allowlist.md.",
  "type": "object",
  "required": ["schema_version", "pepper_required", "events"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "pepper_required": {
      "type": "boolean",
      "const": true
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": ["name", "category", "retention_days", "properties"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "maxLength": 64
        },
        "category": {
          "type": "string",
          "enum": ["crash", "reliability", "product"]
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "notes": { "type": "string" },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/property" }
        }
      }
    },
    "property": {
      "type": "object",
      "required": ["name", "type", "pii_class"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "maxLength": 64
        },
        "type": {
          "type": "string",
          "enum": ["bool", "int", "enum", "string_semver"]
        },
        "values": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pii_class": {
          "type": "string",
          "enum": ["none", "pseudo"],
          "description": "identifier and freetext are banned by the CI gate; schema rejects them here."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "enum" } } },
          "then": { "required": ["values"] }
        },
        {
          "if": { "properties": { "type": { "not": { "const": "enum" } } } },
          "then": { "not": { "required": ["values"] } }
        }
      ]
    }
  }
}
